# Copy to .env and edit for your deployment. `docker compose up` reads it.

# Postgres password (user/db are both `ed`).
POSTGRES_PASSWORD=ed

# Session cookie signing secret — CHANGE THIS in production.
ED_JWT_SECRET=change-me-to-a-long-random-string
# Set true when serving the dashboard over HTTPS.
ED_SECURE_COOKIES=false

# Soketi app credentials (must match between backend and soketi services).
SOKETI_APP_ID=ed-app
SOKETI_APP_KEY=ed-key
SOKETI_APP_SECRET=change-me-soketi-secret

# The dashboard's websocket is proxied through the backend's own origin, so
# there's nothing else to configure for the browser — it works over HTTP or
# HTTPS, on localhost, a LAN IP, or a domain.

# Dashboard/API port.
ED_PORT=3400
