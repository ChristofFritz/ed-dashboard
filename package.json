{
  "name": "ed-dashboard",
  "version": "0.1.0",
  "private": true,
  "license": "GPL-3.0-or-later",
  "author": "Christof Fritz",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c yellow,cyan \"npm run dev -w backend\" \"npm run start -w frontend\"",
    "build": "npm run build -w frontend && npm run build -w backend",
    "start": "npm run start -w backend",
    "test": "npm run test -w backend && npm run test:client",
    "client": "cd client && go run .",
    "client:build": "cd client && go build -o ed-dashboard-client .",
    "test:client": "cd client && go test ./...",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=26"
  }
}
